# =====================================================================
# Configuration for Book a Call (Calendly-like)
# =====================================================================

# Note: Hugo's strict security policy requires environment variables
# to be prefixed with HUGO_ to be readable via getenv.
# ⚠️ IMPORTANT: Paste your Google Apps Script deployment URL here
# (See TO_SIMO_DO.md for step-by-step setup instructions)
HUGO_GOOGLE_APPS_SCRIPT_URL="REPLACE_WITH_YOUR_APPS_SCRIPT_URL"

# The email address that should receive notifications and act as the host
HUGO_OWNER_EMAIL="mattioli.simone.10@gmail.com"
